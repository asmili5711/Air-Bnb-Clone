<% layout("layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-10 offset-1">
    <h3>Your Bookings</h3>
    <% if (bookings.length === 0) { %>
      <p class="text-muted mt-3">No bookings yet.</p>
    <% } else { %>
      <div class="list-group mt-3">
        <% bookings.forEach(b => { %>
          <a class="list-group-item list-group-item-action" href="/bookings/<%= b._id %>">
            <div class="d-flex w-100 justify-content-between">
              <h5 class="mb-1"><%= b.listing.title %></h5>
              <small><%= b.createdAt.toLocaleDateString() %></small>
            </div>
            <p class="mb-1">Order: <%= b.orderId %></p>
            <small>₹ <%= (b.amount/100).toLocaleString("en-IN") %> <%= b.currency %></small>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>
